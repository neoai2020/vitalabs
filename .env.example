# ── Vite client-side variables (prefixed with VITE_) ──

# Uprails publishable key for the Web SDK (safe for client-side)
VITE_UPRAILS_PUBLISHABLE_KEY=pk_prd_YOUR_PUBLISHABLE_KEY

# Supabase project connection
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Vapi (existing — voice call feature)
VITE_VAPI_API_KEY=
VITE_VAPI_ASSISTANT_ID=
VITE_VAPI_PHONE_NUMBER_ID=


# ── Supabase Edge Function secrets (set via Supabase dashboard or CLI) ──
# These are NOT exposed to the client.
#
#   supabase secrets set UPRAILS_SECRET_KEY=prd_YOUR_SECRET_KEY
#   supabase secrets set UPRAILS_PROFILE_ID=YOUR_PROFILE_ID
#
# UPRAILS_SECRET_KEY=prd_YOUR_SECRET_KEY
# UPRAILS_PROFILE_ID=YOUR_PROFILE_ID
